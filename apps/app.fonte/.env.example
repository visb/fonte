# API URL é resolvida automaticamente em lib/api.ts:
# Android emulador → http://10.0.2.2:3000/api/v1
# iOS/web         → http://localhost:3000/api/v1
# Defina EXPO_PUBLIC_API_URL aqui apenas para sobrescrever (ex: dispositivo físico)
EXPO_PUBLIC_API_URL=

# Sentry (story 43). Sem DSN o SDK fica inerte.
EXPO_PUBLIC_SENTRY_DSN=
EXPO_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=0.1
EXPO_PUBLIC_SENTRY_PROFILES_SAMPLE_RATE=1.0

# Build/EAS — upload de source maps (nunca commitar o token):
# SENTRY_AUTH_TOKEN, SENTRY_ORG, SENTRY_PROJECT (default fonte-app)
