# URL base da API (mesma da [[38]] — endpoints públicos /public/associates)
VITE_API_URL=http://localhost:3000/api/v1

# URL base da API da Pagar.me (tokenização client-side). Default produção abaixo.
VITE_PAGARME_API_URL=https://api.pagar.me/core/v5

# Taxas de cartão da Pagar.me, espelhando PAGARME_CARD_FEE_* do backend ([[41]]).
# Usadas SÓ para exibir o gross-up na tela (preview); o valor cobrado oficial vem do backend.
VITE_PAGARME_CARD_FEE_PCT=0.0399
VITE_PAGARME_CARD_FEE_FIXED=0.39

# Chave pública (appId, pk_...) de tokenização da Pagar.me (client-side). Em DEV
# fica vazia e o tokenizer usa um stub (cardToken fake). Ver src/lib/cardTokenizer.ts.
VITE_PAGARME_PUBLIC_KEY=

# Sentry (story 43). Sem DSN o SDK fica inerte.
VITE_SENTRY_DSN=
VITE_SENTRY_RELEASE=
VITE_SENTRY_TRACES_SAMPLE_RATE=0.1
VITE_SENTRY_PROFILES_SAMPLE_RATE=1.0

# Build/CI — upload de source maps (nunca commitar o token):
# SENTRY_AUTH_TOKEN, SENTRY_ORG, SENTRY_PROJECT (default fonte-associados)
