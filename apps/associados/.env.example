# URL base da API (mesma da [[38]] — endpoints públicos /public/associates)
VITE_API_URL=http://localhost:3000/api/v1

# Taxas de cartão do AbacatePay, espelhando ABACATEPAY_CARD_FEE_* do backend ([[38]]).
# Usadas SÓ para exibir o gross-up na tela (preview); o valor cobrado oficial vem do backend.
VITE_ABACATEPAY_CARD_FEE_PCT=0.0399
VITE_ABACATEPAY_CARD_FEE_FIXED=0.49

# Chave pública de tokenização do AbacatePay (client-side). Em DEV fica vazia e
# o tokenizer usa um stub (cardToken fake). Ver src/lib/cardTokenizer.ts.
VITE_ABACATEPAY_PUBLIC_KEY=
