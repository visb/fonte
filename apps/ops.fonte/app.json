{
  "expo": {
    "name": "ops.fonte",
    "slug": "ops-fonte",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "ops-fonte",
    "userInterfaceStyle": "light",
    "newArchEnabled": false,
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#2563eb"
      },
      "package": "org.fonte.ops"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "@sentry/react-native"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
