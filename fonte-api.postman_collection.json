            "body": {
              "mode": "raw",
              "raw": "{\n  \"type\": \"PERMISSION_TYPE\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/staff/{{staffId}}/permissions", "host": ["{{baseUrl}}"], "path": ["staff", "{{staffId}}", "permissions"] }
          }
        },
        {
          "name": "Remove Staff Permission",
          "request": {
            "method": "DELETE",
            "url": { "raw": "{{baseUrl}}/staff/{{staffId}}/permissions/:type", "host": ["{{baseUrl}}"], "path": ["staff", "{{staffId}}", "permissions", ":type"] }
          }
        }
      ]
    },
