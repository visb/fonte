          "name": "Delete Staff",
          "request": {
            "method": "DELETE",
            "url": { "raw": "{{baseUrl}}/staff/{{staffId}}", "host": ["{{baseUrl}}"], "path": ["staff", "{{staffId}}"] }
          }
        },
        {
          "name": "Upload Staff Photo",
          "request": {
            "method": "POST",
            "body": {
              "mode": "formdata",
              "formdata": [{ "key": "file", "type": "file", "src": "" }]
            },
            "url": { "raw": "{{baseUrl}}/staff/{{staffId}}/photo", "host": ["{{baseUrl}}"], "path": ["staff", "{{staffId}}", "photo"] }
          }
        },
        {
          "name": "Get Staff Permissions",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/staff/{{staffId}}/permissions", "host": ["{{baseUrl}}"], "path": ["staff", "{{staffId}}", "permissions"] }
          }
        },
        {
          "name": "Add Staff Permission",
