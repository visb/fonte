{
  "info": {
    "name": "Fonte de Misericórdia API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3000/api/v1" },
    { "key": "token", "value": "" },
    { "key": "houseId", "value": "{{houseId}}" },
    { "key": "residentId", "value": "{{residentId}}" },
    { "key": "relativeId", "value": "{{relativeId}}" },
    { "key": "staffId", "value": "{{staffId}}" },
    { "key": "ministryId", "value": "{{ministryId}}" },
    { "key": "supportGroupId", "value": "{{supportGroupId}}" },
    { "key": "meetingId", "value": "{{meetingId}}" },
    { "key": "incidentId", "value": "{{incidentId}}" },
    { "key": "itemId", "value": "{{itemId}}" },
    { "key": "templateId", "value": "{{templateId}}" }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.access_token) {",
                  "  pm.collectionVariables.set('token', res.access_token);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@fonte.com\",\n  \"password\": \"senha123\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/auth/login", "host": ["{{baseUrl}}"], "path": ["auth", "login"] }
          }
        },
        {
          "name": "Change Password",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"newPassword\": \"novaSenha123\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/auth/change-password", "host": ["{{baseUrl}}"], "path": ["auth", "change-password"] }
          }
        }
      ]
    },
