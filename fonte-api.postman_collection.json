              "mode": "raw",
              "raw": "{\n  \"name\": \"Nome do Staff\",\n  \"email\": \"staff@fonte.com\",\n  \"password\": \"senha123\",\n  \"role\": \"OPERATOR\",\n  \"houseId\": \"{{houseId}}\",\n  \"supportGroupId\": null,\n  \"phone\": \"+5511999999999\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/staff", "host": ["{{baseUrl}}"], "path": ["staff"] }
          }
        },
        {
          "name": "Update Staff",
          "request": {
