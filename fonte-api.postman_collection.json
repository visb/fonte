            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Nome Atualizado\",\n  \"role\": \"COORDINATOR\",\n  \"houseId\": \"{{houseId}}\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/staff/{{staffId}}", "host": ["{{baseUrl}}"], "path": ["staff", "{{staffId}}"] }
