DATABASE_URL=postgres://fonte:fonte@localhost:5432/fonte_dev
DATABASE_URL_TEST=postgres://fonte:fonte@localhost:5432/fonte_test
JWT_SECRET=changeme_use_a_long_random_string_in_production
JWT_EXPIRES_IN=7d
PORT=3000
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173

# Redis (cache da contagem de filhos — story 59). Vazio = cache inerte (recalcula sempre).
REDIS_URL=redis://localhost:6379

# Claude AI (para extração de fichas de acolhimento)
ANTHROPIC_API_KEY=

# Storage (Railway Object Storage — leave empty to use local disk in development)
AWS_S3_BUCKET_NAME=
AWS_ENDPOINT_URL=
AWS_DEFAULT_REGION=auto
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Backup (segundo bucket no mesmo provider — reusa endpoint/region/credenciais acima)
BACKUP_ENABLED=false            # true em produção para ligar o backup semanal (dom 04:00)
BACKUP_S3_BUCKET_NAME=          # segundo bucket (criar no provider antes de ativar)
BACKUP_RETENTION_COUNT=4        # mantém os N dumps mais recentes
# Caminho dos binários pg_dump/pg_restore (v16). Default usa o PATH.
PG_DUMP_PATH=pg_dump
PG_RESTORE_PATH=pg_restore

# Pagar.me — cobrança recorrente de associados (story 41)
# Sem chave: a integração de assinatura fica indisponível (ServiceUnavailable).
PAGARME_SECRET_KEY=
PAGARME_BASE_URL=https://api.pagar.me/core/v5
# Webhook autenticado por HTTP Basic (usuário/senha configurados no painel Pagar.me).
PAGARME_WEBHOOK_USER=
PAGARME_WEBHOOK_PASSWORD=
# Taxas de cartão p/ gross-up (ajustar à conta). gross=(net+fixed)/(1-pct)
PAGARME_CARD_FEE_PCT=0.0399
PAGARME_CARD_FEE_FIXED=0.39

# WhatsApp Meta Cloud API — cobrança de associados (story 39)
# Sem credencial: o envio é best-effort (loga e segue, não derruba o job das 9h).
# Iniciar conversa exige TEMPLATE aprovado pela Meta (com botão de URL dinâmica
# que recebe o payment_token). Anotar aqui o nome do template aprovado.
META_WA_PHONE_NUMBER_ID=
META_WA_TOKEN=
META_WA_TEMPLATE_NAME=cobranca_associado
# Template com 2 botões de URL (pagar + cancelar), usado a partir do 3º lembrete
# consecutivo (story 45). Anotar aqui o nome do template aprovado pela Meta.
META_WA_TEMPLATE_NAME_CANCELABLE=cobranca_associado_cancelavel
META_WA_API_VERSION=v21.0
# Base do app público; links <base>/p/<payment_token> e <base>/cancelar/<payment_token>
APP_ASSOCIADOS_URL=

# Sentry (observabilidade — story 43). Sem DSN o SDK fica inerte.
SENTRY_DSN=
SENTRY_ENVIRONMENT=                 # fallback: NODE_ENV
SENTRY_RELEASE=                     # opcional; setar no CI (ex.: git sha)
SENTRY_TRACES_SAMPLE_RATE=0.1       # 1.0 em dev se quiser tudo
SENTRY_PROFILES_SAMPLE_RATE=1.0     # relativo às traces amostradas
